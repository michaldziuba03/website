---
import { getImage } from "astro:assets";
import me from "../../assets/me.png";
import { Dots } from "./Dots";
import { Socials } from "./Socials";
import { Button } from "../Button";
import { LuArrowDownRight } from "react-icons/lu";
import { Container } from "../Container";

const meImg = await getImage({ src: me, format: "webp" });
---

<Container>
  <section class="w-full flex items-center justify-between gap-10">
    <div class="lg:max-w-150 py-24 md:py-32 lg:py-40 w-full">
      <h1
        class="text-[40px] md:text-[56px] lg:text-[70px] xl:text-[80px] font-bold leading-[0.9]"
      >
        <span class="block mb-1 md:mb-2">Software developer.</span>
        <span class="block text-primary">contributor.</span>
      </h1>
      <p class="my-5 max-w-120 text-lg leading-relaxed text-foreground/90">
        I'm Michał, a software developer from Poland. I focus on building
        reliable applications for the web.
      </p>

      <div class="flex gap-5">
        <Button href="#experience">
          My experience
          <LuArrowDownRight className="w-5 h-5" />
        </Button>
        <Button variant="secondary" href="#contact">Contact</Button>
      </div>

      <div class="mt-[60px]">
        <Socials />
      </div>
    </div>

    <div>
      <div class="relative hidden lg:block">
        <Dots
          className="absolute left-[90%] bottom-0 -translate-x-1/2 z-0 hidden 2xl:block"
        />
        <picture>
          <source
            media="(min-width: 1024px)"
            srcset={meImg.src}
            type="image/webp"
          />
          <img
            alt="Michał Dziuba"
            class="relative z-10 max-w-[480px] xl:max-w-[540px]"
          />
        </picture>
      </div>
    </div>
  </section>
</Container>
