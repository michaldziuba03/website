---
import { Container } from "../Container";
import { TechStack } from "./TechStack";
import { Terminal } from "./Terminal";
---

<Container>
  <section
    class="py-16 md:py-24 lg:py-32 flex flex-col lg:flex-row items-center justify-between gap-12"
  >
    <div class="flex-1 min-w-0">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4">About</h2>
      <p class="max-w-xl leading-[1.6] text-foreground">
        I'm Michał, a Poland-based developer and open-source enthusiast since
        2018. Outside of work, I spend my time gaming, listening to metal, and
        exploring history or pixel art.
      </p>

      <div class="mt-12">
        <h3 class="text-2xl font-bold">Tech stack</h3>
        <p class="mt-1 mb-5 text-foreground">
          Some technologies I use on daily basis.
        </p>
        <TechStack />
      </div>
    </div>

    <div class="hidden lg:flex shrink-0 items-center">
      <Terminal client:load />
    </div>
  </section>
</Container>
