---
import Layout from "../layouts/Layout.astro";
import { ScrollToTop } from "../components/ScrollToTop";
import Head from "../components/Head.astro";
import "../styles/animations.css";
import Hero from "../components/landing/Hero.astro";
import About from "../components/landing/About.astro";
import Experience from "../components/landing/Experience.astro";
import LatestPosts from "../components/landing/LatestPosts.astro";
import Contact from "../components/landing/Contact.astro";
---

<head>
  <Head
    title="Michał Dziuba"
    description="I'm Michał, a software developer and open source contributor building applications for the web."
  />
</head>
<Layout>
  <div class="flex flex-col w-full items-center">
    <Hero />
    <About />
    <Experience />
    <LatestPosts />
    <Contact />
  </div>
  <ScrollToTop client:only />
</Layout>
