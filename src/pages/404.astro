---
import Layout from "../layouts/Layout.astro";
import Head from "../components/Head.astro";
import { Container } from "../components/Container";
import { Button } from "../components/Button";
import { LuArrowLeft } from "react-icons/lu";
---

<Layout>
  <Head
    slot="head"
    title="404 - Page Not Found"
    description="The page you are looking for does not exist."
  />
  <Container>
    <div
      class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4"
    >
      <h1 class="text-7xl md:text-9xl font-black text-primary mb-4">404</h1>
      <h2 class="text-3xl md:text-5xl font-bold mb-4">Page not found</h2>
      <p class="text-lg text-foreground/70 mb-6 max-w-lg">
        Oops! The page you are looking for might have been removed, had its name
        changed, or is temporarily unavailable.
      </p>

      <Button href="/">
        <LuArrowLeft />
        Back to Home
      </Button>
    </div>
  </Container>
</Layout>
