---
import type { GetStaticPaths } from "astro";
import Layout from "../../layouts/Layout.astro";
import { getPosts } from "../../content";
import PostList from "../../components/blog/PostList.astro";
import CategoryList from "../../components/blog/CategoryList.astro";
import Head from "../../components/Head.astro";

interface Props {
  page: {
    data: any[];
  };
}

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const posts = await getPosts();

  return paginate(posts, {
    pageSize: 20,
  });
};

const { page } = Astro.props;
---

<Layout>
  <Head
    slot="head"
    title="Blog - Michał Dziuba"
    description="Explore my latest posts, guides, and personal stories."
  />
  <div class="px-4 sm:px-6 md:px-8 max-w-7xl w-full mx-auto py-12 md:py-20">
    <div class="flex flex-col gap-4 mb-12">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Blog</h1>
      <p class="text-gray-600 dark:text-gray-400">
        Explore my latest posts, guides, and personal stories.
      </p>
    </div>

    <CategoryList activeCategory="all" />
    <PostList posts={page.data} page={page} />
  </div>
</Layout>
